{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "next build",
  "framework": "nextjs",
  "functions": {
    "app/api/**/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/recurring-bookings",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/cancel-stale",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/sla-disputes",
      "schedule": "0 4 * * *"
    }
  ]
}

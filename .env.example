# 🌍 SilverConnect Global - Environment Configuration

# ============================================
# APP CONFIGURATION
# ============================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# SUPABASE CONFIGURATION
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgres://postgres:postgres@localhost:5432/silverconnect
DB_NAME=silverconnect
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# STRIPE PAYMENT CONFIGURATION
# ============================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_test_xxx

# ============================================
# EMAIL CONFIGURATION
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@silverconnect.global
SMTP_FROM_NAME=SilverConnect Global

# ============================================
# AI CUSTOMER SERVICE AGENT CONFIGURATION
# ============================================
# AI Provider Configuration (Required - Choose one)
# Option 1: OpenAI
OPENAI_API_KEY=your_openai_api_key

# Option 2: Microsoft Foundry (Alternative to OpenAI)
# FOUNDRY_PROJECT_ENDPOINT=https://your-foundry-project.openai.azure.com/
# FOUNDRY_MODEL_DEPLOYMENT_NAME=your-model-deployment-name

# AI Agent Server Configuration
AI_AGENT_URL=http://localhost:8000
PORT=8000

# ============================================
# SMS CONFIGURATION (Optional - Twilio)
# ============================================
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# MONITORING & OBSERVABILITY
# ============================================
SENTRY_DSN=https://your-sentry-key@sentry.io/project-id
DATADOG_API_KEY=your-datadog-api-key
DATADOG_SITE=datadoghq.com

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_ANALYTICS=true
ENABLE_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_PUSH_NOTIFICATIONS=true

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# API RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# JWT SECRET
# ============================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ============================================
# EXTERNAL API KEYS
# ============================================
GOOGLE_MAPS_API_KEY=your-google-maps-key
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key

# ============================================
# TESTING
# ============================================
TEST_USER_EMAIL=test@silverconnect.global
TEST_USER_PASSWORD=TestPassword123!

# ============================================
# DEPLOYMENT
# ============================================
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID=your-project-id
